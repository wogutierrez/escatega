---

// Look up two folders to the content folder
const posts = await Astro.glob('../../content/posts/*.md');
---

<BaseLayout title="Articles | Escatega">
  <header class="py-5 bg-light border-bottom">
    <div class="container py-5 text-center">
      <h1 class="display-4 fw-extrabold text-dark mb-3">Our Articles</h1>
      <p class="lead text-secondary mx-auto" style="max-width: 600px;">
        Insights, guides, and practical tips on digital presence, tech, and AI skills.
      </p>
      <div class="mx-auto mt-4" style="width: 60px; height: 4px; background-color: #ff6b35"></div>
    </div>
  </header>

  <section class="py-5 bg-white">
    <div class="container" style="max-width: 900px;">
      <div class="row g-4">
        {posts.map(post => {
          const slug = post.file.split('/').pop().replace('.md', '');
          
          return (
            <div class="col-md-6">
              <div class="card h-100 feature-card p-4 shadow-sm border-0 bg-light">
                <div class="card-body d-flex flex-column justify-content-between">
                  <div>
                    <span class="text-uppercase fw-bold text-primary small d-block mb-2">
                      {post.frontmatter.pubDate || 'Blog Post'}
                    </span>
                    <h3 class="h4 fw-bold text-dark mb-3">
                      {post.frontmatter.title}
                    </h3>
                    <p class="text-secondary small line-clamp">
                      {post.frontmatter.description || 'Read our latest insights...'}
                    </p>
                  </div>
                  <div class="mt-4">
                    <a href={`/articles/${slug}`} class="btn btn-outline-dark rounded-pill btn-sm px-4">
                      Read Article →
                    </a>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .line-clamp {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;  
    overflow: hidden;
  }
</style>