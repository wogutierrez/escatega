---
// 1. We import the stylesheet here in the frontmatter. 
// Astro automatically recognizes this and applies it globally to all pages using this layout!
import '../styles/styles.css';

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title || 'Escatega'}</title>
  
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- FontAwesome for Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  
  <style>
    @import "https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Roboto:wght@400;500&display=swap";
    :root {
      --eg-orange: #ff6b35;
      --eg-black: #111111;
      --eg-gray: #555555;
      --eg-light: #f8f9fa;
      --bs-body-font-family: "Roboto", sans-serif;
      --bs-heading-font-family: "Inter", sans-serif;
    }
    .text-primary, .btn-primary { color: var(--eg-orange) !important; }
    .btn-primary {
      background-color: var(--eg-orange) !important;
      border-color: var(--eg-orange) !important;
      color: #fff !important;
      font-weight: 600;
      transition: all .3s ease;
    }
    .btn-primary:hover {
      background-color: #e0531f !important;
      border-color: #e0531f !important;
    }
    .bg-dark { background-color: var(--eg-black) !important; }
    .text-secondary { color: var(--eg-gray) !important; }
    .navbar-brand img { max-height: 80px; }
    .hero-section { padding: 100px 0; }
    .feature-card { border: 1px solid transparent; transition: transform .3s ease, box-shadow .3s ease; }
    .feature-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px #00000014; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
    <div class="container">
      <a class="navbar-brand" href="/">
        <img src="/escatega-logo.png" alt="EscaTega Tech Mentorship & Solutions">
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="mainNav">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/foundation">The Digital Foundation</a></li>
          <li class="nav-item"><a class="nav-link" href="/about">About Us</a></li>
          <li class="nav-item"><a class="nav-link" href="/articles">Articles</a></li>
          <li class="nav-item"><a class="nav-link" href="/team"">Meet the Team</a></li>
          <li class="nav-item"><a class="nav-link" href="/contact">Contact Us</a></li>
          <li class="nav-item ms-lg-3">
            <a class="btn btn-primary btn-sm px-4 rounded-pill" href="/foundation#apply">Apply Now</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="bg-dark text-white border-top border-secondary py-4">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
          <span class="small opacity-50">&copy; 2026 Escatega. All rights reserved.</span>
        </div>
        <div class="col-md-6 text-center text-md-end">
          <a href="/" class="text-white mx-2 small text-decoration-none opacity-75 hover-opacity-100">Home</a>
          <a href="/about" class="text-white mx-2 small text-decoration-none opacity-75 hover-opacity-100">About Us</a>
          <a href="/articles" class="text-white mx-2 small text-decoration-none opacity-75 hover-opacity-100">Articles</a>
          <a href="/contact" class="text-white mx-2 small text-decoration-none opacity-75 hover-opacity-100">Contact</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Bootstrap 5 Bundle JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>