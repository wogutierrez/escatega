---
import ArticleLayout from '../../layouts/ArticleLayout.astro';

// Use Astro.glob to find all posts in src/content/posts/
export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/posts/*.md');
  
  return posts.map(post => {
    // Extract the filename from the file path
    const id = post.file.split('/').pop().replace('.md', '');
    return {
      params: { id },
      props: { post },
    };
  });
}

// 1. Get the post from props
const { post } = Astro.props;

// 2. Extract the Content component directly from the post object (NO await, NO parentheses)
const Content = post.Content; 
---
<ArticleLayout frontmatter={post.frontmatter}>
  <Content />
</ArticleLayout>