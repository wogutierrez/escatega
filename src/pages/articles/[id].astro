---
export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/posts/*.md');
  return posts.map(post => {
    const id = post.file.split('/').pop().replace('.md', '');
    return {
      params: { id },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = post;
---

<Content />