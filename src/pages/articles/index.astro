---
import ArticleLayout from '../../layouts/ArticleLayout.astro';

// 1. Fetch all of your markdown posts
const posts = await Astro.glob('../../content/posts/*.md');
---

<ArticleLayout frontmatter={{ title: "Articles" }}>
  <h1>All Articles</h1>
  <ul>
    {posts.map(post => {
      // 2. Format the URL slug from the filename
      const slug = post.file.split('/').pop().replace('.md', '');
      
      return (
        <li>
          <a href={`/articles/${slug}`}>
            {post.frontmatter.title || 'Untitled Article'}
          </a>
        </li>
      );
    })}
  </ul>
</ArticleLayout>