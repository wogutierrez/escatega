---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Fetch all markdown posts
const posts = await Astro.glob('../../content/posts/*.md');
---

<BaseLayout title="Articles | Escatega">
  <!-- Header Section -->
  <header class="py-5 bg-white border-bottom">
    <div class="container py-5 text-center">
      <h1 class="display-4 fw-extrabold text-dark mb-3">Our Articles</h1>
      <p class="lead text-secondary mx-auto" style="max-width: 600px;">
        Insights, guides, and practical tips on digital presence, tech, and AI skills.
      </p>
      <div class="mx-auto mt-4" style="width: 60px; height: 4px; background-color: var(--eg-orange)"></div>
    </div>
  </header>

  <!-- Articles Grid Section (Flipped to bg-light for beautiful contrast) -->
  <section class="py-5 bg-light">
    <div class="container" style="max-width: 900px;">
      <div class="row g-4">
        {posts.map(post => {
          const slug = post.file.split('/').pop().replace('.md', '');
          
          return (
            <div class="col-md-6">
              {/* Pure white card with a subtle top border using your brand orange */}
              <div 
                class="card h-100 feature-card p-4 shadow-sm border-0 bg-white" 
                style="border-top: 4px solid var(--eg-orange) !important;"
              >
                <div class="card-body d-flex flex-column justify-content-between">
                  <div>
                    {/* Date using brand orange via text-primary */}
                    <span class="text-uppercase fw-bold text-primary small d-block mb-2">
                      {post.frontmatter.pubDate || 'Blog Post'}
                    </span>
                    
                    {/* Title */}
                    <h3 class="h4 fw-bold text-dark mb-3">
                      {post.frontmatter.title}
                    </h3>
                    
                    {/* Description */}
                    <p class="text-secondary small mb-0">
                      {post.frontmatter.description || 'Read our latest insights...'}
                    </p>
                  </div>
                  
                  {/* Button using your global btn-primary style */}
                  <div class="mt-4">
                    <a href={`/articles/${slug}`} class="btn btn-primary rounded-pill btn-sm px-4">
                      Read Article →
                    </a>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>