---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The Digital Foundation | Escatega">

  <!-- AGITATION HERO SECTION -->
  <header class="py-5 bg-dark text-white text-center">
    <div class="container py-5">
      <h1 class="display-3 fw-extrabold mb-3">
        Stop being invisible.<br /><span class="text-primary"
          >Start being the obvious choice.</span
        >
      </h1>
      <div
        class="mx-auto my-4"
        style="width: 60px; height: 4px; background-color: #ff6b35"
      ></div>
      <div class="mt-4">
        <a
          href="#apply"
          class="btn btn-primary btn-lg px-5 rounded-pill shadow"
          >Apply Now</a
        >
      </div>
    </div>
  </header>

  <!-- THE PAIN POINT PROBLEM SECTION -->
  <section class="py-5 bg-light">
    <div class="container py-4">
      <div class="row justify-content-center text-center mb-5">
        <div class="col-lg-9">
          <h2 class="fw-bold text-dark mb-3">
            You Know You Need a Better Online Presence. But You Haven’t Had
            the Time or Know-How to Build It.
          </h2>
          <p class="lead text-secondary">
            Let’s be honest. Your current digital presence is probably:
          </p>
        </div>
      </div>

      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <ul class="list-group list-group-flush">
              <li
                class="list-group-item p-4 d-flex align-items-start bg-white border-bottom"
              >
                <i
                  class="fa-solid fa-circle-xmark text-danger me-3 fs-4 mt-1"
                ></i>
                <div>
                  <h5 class="fw-bold mb-1 text-dark">
                    A Gmail address that looks unprofessional.
                  </h5>
                </div>
              </li>
              <li
                class="list-group-item p-4 d-flex align-items-start bg-white border-bottom"
              >
                <i
                  class="fa-solid fa-circle-xmark text-danger me-3 fs-4 mt-1"
                ></i>
                <div>
                  <h5 class="fw-bold mb-1 text-dark">
                    A LinkedIn profile that’s just a digital resume.
                  </h5>
                </div>
              </li>
              <li
                class="list-group-item p-4 d-flex align-items-start bg-white border-bottom"
              >
                <i
                  class="fa-solid fa-circle-xmark text-danger me-3 fs-4 mt-1"
                ></i>
                <div>
                  <h5 class="fw-bold mb-1 text-dark">
                    No central hub (a website) where people can learn about
                    you and hire you.
                  </h5>
                </div>
              </li>
              <li
                class="list-group-item p-4 d-flex align-items-start bg-white"
              >
                <i
                  class="fa-solid fa-circle-xmark text-danger me-3 fs-4 mt-1"
                ></i>
                <div>
                  <h5 class="fw-bold mb-1 text-dark">
                    A feeling that you’re leaving opportunities and money on
                    the table because you’re hard to find and hard to trust
                    online.
                  </h5>
                </div>
              </li>
            </ul>
          </div>

          <div class="text-center mt-5">
            <p class="fs-5 text-dark">
              You’re not alone. But in today’s world,
              <strong>your online presence is your new business card.</strong>
              It’s the first thing clients, recruiters, and partners see.
            </p>
            <h4 class="fw-bold mt-3 text-primary">
              It’s time to change the narrative.
            </h4>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT YOU GET SECTION -->
  <section class="py-5 bg-white">
    <div class="container py-4">
      <div class="text-center mb-5">
        <h2 class="fw-bold text-dark">
          Here’s Everything you Get when you Book the Digital Foundation:
        </h2>
        <div
          class="mx-auto mt-2"
          style="width: 50px; height: 3px; background-color: #ff6b35"
        ></div>
      </div>

      <div class="row g-4">
        <!-- Feature 1 -->
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 feature-card p-4 rounded-4 bg-light">
            <div class="card-body">
              <div class="text-primary mb-3">
                <i class="fa-solid fa-id-card fa-2x"></i>
              </div>
              <h4 class="fw-bold card-title text-dark mb-3">
                Professional Identity
              </h4>
              <p class="text-secondary card-text small">
                <strong>Custom Domain & Email:</strong> We secure yourname.com
                and set up your professional email (hello@yourname.com).[cite: 3] No more unprofessional addresses.
              </p>
            </div>
          </div>
        </div>

        <!-- Feature 2 -->
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 feature-card p-4 rounded-4 bg-light">
            <div class="card-body">
              <div class="text-primary mb-3">
                <i class="fa-solid fa-globe fa-2x"></i>
              </div>
              <h4 class="fw-bold card-title text-dark mb-3">
                Personal Website
              </h4>
              <p class="text-secondary card-text small mb-2">
                A sleek, one-page website that acts as your digital home. It
                includes:
              </p>
              <ul class="text-secondary small ps-3">
                <li>A powerful, client-focused bio.</li>
                <li>A clear “who I help” section.</li>
                <li>A portfolio/media section.</li>
                <li>
                  A contact form that makes it easy for clients to reach you.
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Feature 3 -->
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 feature-card p-4 rounded-4 bg-light">
            <div class="card-body">
              <div class="text-primary mb-3">
                <i class="fa-solid fa-bolt-lightning fa-2x"></i>
              </div>
              <h4 class="fw-bold card-title text-dark mb-3">
                Lead Generation Machine
              </h4>
              <p class="text-secondary card-text small">
                <strong>A High-Converting LinkedIn Profile:</strong> We
                rewrite your headline and “About” section to position you as
                an authority and attract inbound opportunities.
              </p>
            </div>
          </div>
        </div>

        <!-- Feature 4 -->
        <div class="col-md-6 col-lg-6">
          <div class="card h-100 feature-card p-4 rounded-4 bg-light">
            <div class="card-body">
              <div class="text-primary mb-3">
                <i class="fa-solid fa-envelope-open-text fa-2x"></i>
              </div>
              <h4 class="fw-bold card-title text-dark mb-3">
                Audience Engine
              </h4>
              <p class="text-secondary card-text small">
                <strong>Newsletter Platform Setup:</strong> We set up your
                Beehiiv/ConvertKit account with a signup form embedded on your
                website, so you can start building an audience you own.[cite: 3]
              </p>
            </div>
          </div>
        </div>

        <!-- Feature 5 -->
        <div class="col-md-6 col-lg-6">
          <div class="card h-100 feature-card p-4 rounded-4 bg-light">
            <div class="card-body">
              <div class="text-primary mb-3">
                <i class="fa-solid fa-share-nodes fa-2x"></i>
              </div>
              <h4 class="fw-bold card-title text-dark mb-3">
                Social Media Hub
              </h4>
              <p class="text-secondary card-text small">
                <strong>A “Link-in-Bio” Page:</strong> A polished landing page
                (using Carrd) that connects all your profiles and projects in
                one place.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ACTION TRIGGER CONVERSION BANNER -->
  <section id="apply" class="py-5 bg-dark text-white text-center">
    <div class="container py-4">
      <h3 class="fw-bold mb-3">
        Ready to claim your corner of the digital space?
      </h3>
      <p
        class="lead text-secondary opacity-75 mb-4 mx-auto"
        style="max-width: 600px"
      >
        Let William and Alan architect your professional blueprint so you can
        stand out, establish unmatched credibility, and expand your impact.
      </p>
      <a
        href="/contact"
        class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm"
        >Book Your Digital Foundation Today</a
      >
    </div>
  </section>

</BaseLayout>