---
// src/pages/ortega.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="William Ortega | Solution Architect & Tech Mentor">
  
  <!-- Main dark background section matching your card's look -->
  <section class="py-5 bg-dark text-white min-vh-100 d-flex align-items-center">
    <div class="container py-5" style="max-width: 800px;">
      
      <!-- HERO -->
      <div class="mb-5">
        <h1 class="display-4 fw-bold text-white mb-2">William Ortega</h1>
        <p class="lead mb-4" style="color: var(--eg-orange); font-weight: 500;">
          Senior Solution Architect & Tech Mentor
        </p>
        <p class="text-light opacity-75 fs-5 mb-4" style="line-height: 1.6;">
          Designing resilient, scalable digital systems today to power the innovations of tomorrow. 
          Bridging the gap between high-level business strategy and robust engineering.
        </p>
        <div class="d-flex gap-3 flex-wrap">
          <a href="#consult" class="btn btn-primary px-4 py-2 rounded-pill shadow">
            Book a Strategy Session
          </a>
          <a href="/" class="btn btn-outline-light px-4 py-2 rounded-pill">
            Back to Escatega
          </a>
        </div>
      </div>

      <div class="my-5 border-bottom border-secondary opacity-25"></div>

      <!-- PERSPECTIVE -->
      <div class="mb-5">
        <h2 class="h5 tracking-wider text-uppercase mb-3" style="color: var(--eg-orange)">/ Perspective</h2>
        <div class="text-light opacity-75 fs-5" style="line-height: 1.7;">
          <p class="mb-4">
            I am a Solution Architect dedicated to turning complex operational challenges into elegant, high-throughput software systems. With a deep foundation in cloud infrastructure, microservices, and system design, I create the technical blueprints that allow organizations to scale reliably.
          </p>
          <p>
            Beyond architecting platforms, my core passion is <strong>Tech Mentorship</strong>. Through Escatega, I mentor engineering teams and rising developers, helping them master architectural patterns, make smart trade-offs, and design with long-term survival in mind.
          </p>
        </div>
      </div>

      <div class="my-5 border-bottom border-secondary opacity-25"></div>

      <!-- CORE PILLARS -->
      <div class="mb-5">
        <h2 class="h5 tracking-wider text-uppercase mb-4" style="color: var(--eg-orange)">/ Core Pillars</h2>
        <div class="row g-4">
          
          <div class="col-md-4">
            <div class="card h-100 feature-card bg-secondary bg-opacity-10 border border-secondary border-opacity-25 p-4 rounded-4 text-white">
              <h3 class="h5 fw-bold mb-3">System Architecture</h3>
              <ul class="list-unstyled text-light opacity-75 small mb-0" style="line-height: 1.8;">
                <li>• Microservices</li>
                <li>• Distributed Systems</li>
                <li>• API Design & Gateways</li>
                <li>• High-Availability</li>
              </ul>
            </div>
          </div>

          <div class="col-md-4">
            <div class="card h-100 feature-card bg-secondary bg-opacity-10 border border-secondary border-opacity-25 p-4 rounded-4 text-white">
              <h3 class="h5 fw-bold mb-3">Cloud Infrastructure</h3>
              <ul class="list-unstyled text-light opacity-75 small mb-0" style="line-height: 1.8;">
                <li>• AWS / Multi-cloud</li>
                <li>• Infrastructure as Code</li>
                <li>• Cost Optimization</li>
                <li>• CI/CD Pipelines</li>
              </ul>
            </div>
          </div>

          <div class="col-md-4">
            <div class="card h-100 feature-card bg-secondary bg-opacity-10 border border-secondary border-opacity-25 p-4 rounded-4 text-white">
              <h3 class="h5 fw-bold mb-3">Leadership & Mentoring</h3>
              <ul class="list-unstyled text-light opacity-75 small mb-0" style="line-height: 1.8;">
                <li>• Tech Team Guidance</li>
                <li>• Architecture Reviews</li>
                <li>• Dev Best Practices</li>
                <li>• 1-on-1 Mentorship</li>
              </ul>
            </div>
          </div>

        </div>
      </div>

      <div class="my-5 border-bottom border-secondary opacity-25"></div>

      <!-- CALL TO ACTION -->
      <div id="consult" class="p-4 p-md-5 bg-secondary bg-opacity-10 border border-secondary border-opacity-50 rounded-4">
        <h3 class="h3 fw-bold mb-2">Let’s build something durable.</h3>
        <p class="text-light opacity-75 mb-4">
          Whether you need a system audit, a cloud deployment strategy, or structured mentorship for your tech team, let’s schedule a brief introductory call.
        </p>
        <a 
          href="https://calendly.com/your-username" 
          target="_blank" 
          rel="noopener noreferrer"
          class="btn btn-primary px-4 py-2 rounded-pill shadow"
        >
          Schedule a 15-Minute Consult
        </a>
      </div>

    </div>
  </section>

</BaseLayout>