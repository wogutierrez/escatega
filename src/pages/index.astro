---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Escatega | Future-Proof Your Skills for the AI Era">
  
  <header class="hero-section bg-white">
    <div class="container">
      <div class="row align-items-center g-5">
        <div class="col-lg-6">
          <h1 class="display-4 fw-extrabold text-dark mb-3">
            Future-Proof Your Skills for the
            <span style="color: var(--eg-orange)">AI Era</span>
          </h1>
          <p class="lead text-secondary mb-4">
            “We help you learn AI tools to improve your skills, make sure
            you’re always needed, and work with confidence in a changing
            world.”
          </p>
          <div class="d-flex gap-3">
            <a
              href="#learning-hub"
              class="btn btn-primary btn-lg px-4 rounded-pill shadow"
              >Learning Hub</a
            >
            <a
              href="/about"
              class="btn btn-outline-dark btn-lg px-4 rounded-pill"
              >Our Story</a
            >
          </div>
        </div>
        <div class="col-lg-6 text-center">
          <img
            src="/path-to-your-image.png"
            alt="Mind expansion and technology integration"
            class="img-fluid rounded-5 shadow-sm border"
          />
        </div>
      </div>
    </div>
  </header>

  <section id="learning-hub" class="py-5 bg-light">
    <div class="container py-4">
      <div class="text-center mb-5">
        <h2 class="fw-bold text-dark">Our Core Service Pillars</h2>
        <div
          class="mx-auto my-2"
          style="width: 60px; height: 4px; background-color: var(--eg-orange)"
        ></div>
      </div>

      <div class="row g-4">
        <div class="col-md-4">
          <div class="card h-100 feature-card shadow-sm p-4 rounded-4">
            <div class="card-body d-flex flex-column">
              <div class="mb-3 text-primary">
                <i class="fa-solid fa-rocket fa-2x"></i>
              </div>
              <h4 class="card-title fw-bold mb-3">
                Launch Your Tech-Enabled Venture
              </h4>
              <p class="card-text text-secondary mb-4">
                “Want to start your own business or make the one you have run
                smoother? We give you the tech skills and guidance to use
                technology as your helper, so you can reach your goals on your
                own terms.”
              </p>
              <a
                href="/about#contact"
                class="btn btn-outline-dark mt-auto rounded-pill w-100"
                >Start Your Journey</a
              >
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card h-100 feature-card shadow-sm p-4 rounded-4">
            <div class="card-body d-flex flex-column">
              <div class="mb-3 text-primary">
                <i class="fa-solid fa-gears fa-2x"></i>
              </div>
              <h4 class="card-title fw-bold mb-3">
                Manage & Automate Your Business
              </h4>
              <p class="card-text text-secondary mb-4">
                “Get the same reliable tech support big companies have. We
                take care of your computers, security, and boring tasks so you
                can focus on growing your business.”
              </p>
              <a
                href="/contact#contact"
                class="btn btn-outline-dark mt-auto rounded-pill w-100"
                >Explore Solutions</a
              >
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card h-100 feature-card shadow-sm p-4 rounded-4">
            <div class="card-body d-flex flex-column">
              <div class="mb-3 text-primary">
                <i class="fa-solid fa-cubes fa-2x"></i>
              </div>
              <h4 class="card-title fw-bold mb-3">The Digital Foundation</h4>
              <p class="card-text text-secondary mb-4">
                Stop being invisible online. Establish a completely unified
                professional identity complete with a custom personal website,
                business domain, and high-converting audience engine.
              </p>
              <a
                href="/foundation"
                class="btn btn-primary mt-auto rounded-pill w-100"
                >Claim Your Space</a
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-5 bg-dark text-white position-relative">
    <div class="container py-4">
      <div class="row align-items-center g-5">
        <div class="col-lg-5">
          <h2 class="display-6 fw-bold">
            Built on a Foundation of Christian Values and Integrity
          </h2>
          <div
            class="my-3"
            style="
              width: 50px;
              height: 3px;
              background-color: var(--eg-orange);
            "
          ></div>
          <p class="text-light opacity-75">
            We hold ourselves to the highest standards of clarity, direct
            communication, and reliable implementation across every client
            milestone.
          </p>
        </div>
        <div class="col-lg-7">
          <div
            class="p-4 bg-secondary bg-opacity-10 border border-secondary rounded-4"
          >
            <p class="lead mb-4">
              We bring together over 20 years each in technology and business.
            </p>
            <ul class="list-unstyled">
              <li class="mb-3 d-flex align-items-start">
                <i
                  class="fa-solid fa-circle-check text-primary me-3 mt-1"
                ></i>
                <span
                  ><strong>William’s Framework:</strong> Background in senior
                  systems administration for international organizations
                  ensures your technology is reliable and secure.</span
                >
              </li>
              <li class="mb-3 d-flex align-items-start">
                <i
                  class="fa-solid fa-circle-check text-primary me-3 mt-1"
                ></i>
                <span
                  ><strong>Alan’s Insight:</strong> Success as an entrepreneur
                  running multiple businesses means we understand your
                  operational needs from day one.</span
                >
              </li>
            </ul>
            <p class="mt-4 mb-0 fw-bold" style="color: var(--eg-orange)">
              Together, we provide solutions that are both technically sound
              and strategically smart.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>